SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Full origins (scheme + host), not just hostnames -- only needed once DEBUG=False.
CSRF_TRUSTED_ORIGINS=

POSTGRES_DB=formula_zany
POSTGRES_USER=formula_zany
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Alternative to the four POSTGRES_* vars above -- if set, this wins.
# What most hosting platforms inject for an attached managed Postgres, e.g.
# postgres://user:password@host:5432/dbname
DATABASE_URL=

STRIPE_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
